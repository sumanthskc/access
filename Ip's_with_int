CREATE TABLE s3tablescatalog.networkautomation.ip_asn_dictionary AS
WITH unique_external_ips AS (
    -- Extract only unique IPs that are NOT AWS internal traffic
    SELECT DISTINCT destination_ip
    FROM networkautomation.joined_logs
    WHERE instance_id IS NOT NULL
      AND (pkt_dst_aws_service IS NULL OR pkt_dst_aws_service = '')
),
ips_with_int AS (
    -- Compute the integer only once per globally unique IP
    SELECT 
        destination_ip,
        CAST(split_part(destination_ip,'.',1) AS bigint)*16777216 +
        CAST(split_part(destination_ip,'.',2) AS bigint)*65536 +
        CAST(split_part(destination_ip,'.',3) AS bigint)*256 +
        CAST(split_part(destination_ip,'.',4) AS bigint) AS ip_int
    FROM unique_external_ips
)
-- Perform the heavy BETWEEN join just once per IP
SELECT 
    l.destination_ip,
    COALESCE(a.autonomous_system_organization, 'Unknown ASN') AS asn_org
FROM ips_with_int l
LEFT JOIN geo_asn_blocks_range a
    ON l.ip_int BETWEEN a.network_start_integer AND a.network_end_integer;

