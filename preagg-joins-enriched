CREATE TABLE networkautomation.vpc_egress_enriched_preagg
WITH (
    format = 'PARQUET',
    external_location = 's3://YOUR-BUCKET-NAME/preaggregate/vpc_egress_enriched_preagg/',
    partitioned_by = ARRAY['account_id', 'region', 'year', 'month', 'day']
)
AS
-- 1. TINY DICTIONARY: Get ONLY unique IPs & services to drastically bypass the join overhead
WITH unique_destinations AS (
    SELECT DISTINCT
        destination_ip,
        pkt_dst_aws_service,
        CAST(split_part(destination_ip,'.',1) AS bigint) AS octet1,
        (
            CAST(split_part(destination_ip,'.',1) AS bigint) * 16777216 +
            CAST(split_part(destination_ip,'.',2) AS bigint) * 65536 +
            CAST(split_part(destination_ip,'.',3) AS bigint) * 256 +
            CAST(split_part(destination_ip,'.',4) AS bigint)
        ) AS ip_int
    FROM joined_logs_2
    WHERE instance_id IS NOT NULL 
      AND destination_ip IS NOT NULL
),

-- 2. PREP REFERENCE TABLES (Same fast octet math as before)
geo_prepared AS (
    SELECT network_start_integer, network_end_integer, geoname_id,
           CAST(network_start_integer / 16777216 AS bigint) AS octet1
    FROM geo_country_blocks_range
),
asn_prepared AS (
    SELECT network_start_integer, network_end_integer, autonomous_system_organization,
           CAST(network_start_integer / 16777216 AS bigint) AS octet1
    FROM geo_asn_blocks_range
),
aws_prepared AS (
    SELECT network_start_int, network_end_int, service, region AS aws_region,
           CAST(network_start_int / 16777216 AS bigint) AS octet1
    FROM networkautomation.aws_ip_ranges_int
),

-- 3. RESOLVE IPS QUICKLY: Heavy BETWEEN joins happen here, but only on a few thousand rows!
resolved_ips AS (
    SELECT 
        u.destination_ip,
        u.pkt_dst_aws_service,
        loc.country_name,
        a.autonomous_system_organization AS asn_org,
        aws.service AS aws_service,
        aws.aws_region
    FROM unique_destinations u
    LEFT JOIN geo_prepared g 
        ON u.octet1 = g.octet1 AND u.ip_int BETWEEN g.network_start_integer AND g.network_end_integer
    LEFT JOIN geo_country_locations loc 
        ON g.geoname_id = loc.geoname_id
    LEFT JOIN asn_prepared a 
        ON u.octet1 = a.octet1 AND u.ip_int BETWEEN a.network_start_integer AND a.network_end_integer
    LEFT JOIN aws_prepared aws 
        ON u.octet1 = aws.octet1 AND u.ip_int BETWEEN aws.network_start_int AND aws.network_end_int
       AND aws.service = u.pkt_dst_aws_service
)

-- 4. FINAL ASSEMBLY: Exact matches (=) back to the massive table, then Aggregate
SELECT
    c.account_name,
    c.application_id,
    c.instance_id,
    c.vpc_id,
    c.client_ip AS srcaddr,
    c.destination_ip AS dstaddr,
    c.dstport,
    COALESCE(c.domain, 'unknown') AS query_name,
    r.country_name,
    r.asn_org,
    
    CASE 
        WHEN r.aws_service IS NULL THEN 'NON-AWS' 
        ELSE r.aws_service 
    END AS final_service_type,
    
    r.aws_region,
    CASE 
        WHEN r.aws_service IS NULL THEN 'Internet'
        WHEN r.aws_region = c.region THEN 'Same-Region'
        WHEN r.aws_region IS NOT NULL AND r.aws_region != c.region THEN 'Cross-Region'
        ELSE 'Unknown'
    END AS region_scope,
    
    SUM(c.total_bytes) / (1024.0 * 1024.0 * 1024.0) AS data_out_gb,
    SUM(c.total_bytes) AS total_bytes,

    -- PARTITIONS AT THE END
    c.account_id,
    c.region,
    c.year,
    c.month,
    c.day

FROM joined_logs_2 c
-- Blazing fast exact hash join back to our dictionary
LEFT JOIN resolved_ips r 
    ON c.destination_ip = r.destination_ip 
   AND c.pkt_dst_aws_service = r.pkt_dst_aws_service

WHERE c.instance_id IS NOT NULL

GROUP BY 
    c.account_name, c.application_id, c.instance_id, c.vpc_id,
    c.client_ip, c.destination_ip, c.dstport, c.domain,
    r.country_name, r.asn_org, r.aws_service, r.aws_region,
    c.region, c.account_id, c.year, c.month, c.day;


