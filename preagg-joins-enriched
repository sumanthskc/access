    c.account_name, c.application_id, c.instance_id, c.vpc_id,
    c.client_ip, c.destination_ip, c.dstport, c.domain,
    r.country_name, r.asn_org, r.aws_service, r.aws_region,
    c.region, c.account_id, c.year, c.month, c.day

-- 🛑 Limit added so it returns results instantly
LIMIT 100;
