    c.region,
    c.year,
    c.month,
    c.day

FROM joined_logs_2 c
LEFT JOIN resolved_ips r 
    ON c.destination_ip = r.destination_ip 
   AND COALESCE(c.pkt_dst_aws_service, 'NON-AWS') = COALESCE(r.pkt_dst_aws_service, 'NON-AWS')

WHERE c.instance_id IS NOT NULL
