SELECT 
    b.network_start_integer,
    b.network_end_integer,
    l.country_iso_code,
    l.country_name,
    l.continent_name,
    a.autonomous_system_number,
    a.autonomous_system_organization
FROM geo_country_blocks_range b
-- 1. Explicitly cast geoname_id to match the string type in locations
LEFT JOIN geo_country_locations l 
    ON CAST(b.geoname_id AS varchar) = l.geoname_id
-- 2. Join ASN data. (Assuming the network ranges align exactly)
LEFT JOIN geo_ans_block_range a 
    ON b.network_start_integer = a.network_start_integer 
    AND b.network_end_integer = a.network_end_integer
