# AGG 10: Network Intelligence Final
# Uses: vpc_egress_base, deduped_dns, ec2_full,
#       acct_biz_lookup, ip_metadata
# All equi-joins — no BETWEEN range joins
# ──────────────────────────────────────────────────────────────
print("[AGG 10] Network Intelligence Final...")

agg10_df = spark.sql(f"""
    SELECT
        COALESCE(e.account_name,  a.account_name, 'UNKNOWN') AS account_name,
        COALESCE(e.biz_unit,      a.biz_unit,     'UNKNOWN') AS biz_unit,
        COALESCE(e.application_id,                'UNKNOWN') AS application_id,
        v.account_id, v.region, v.vpc_id, v.instance_id,
        v.srcaddr                                            AS client_ip,
        v.dstaddr                                            AS destination_ip,
        COALESCE(d.primary_domain, 'UNKNOWN')                AS domain,
        v.pkt_dst_aws_service,
        v.traffic_path,
        m.country_name,
        m.asn_org,
        COALESCE(m.final_service_type, 'NON-AWS')            AS final_service_type,
        m.aws_region,
        CASE
            WHEN m.final_service_type = 'NON-AWS'
              OR m.final_service_type IS NULL THEN 'Internet'
            WHEN m.aws_region = v.region          THEN 'Same-Region'
            WHEN m.aws_region IS NOT NULL
             AND m.aws_region != v.region          THEN 'Cross-Region'
            ELSE 'Unknown'
        END                                                  AS region_scope,
        ROUND(SUM(v.total_bytes) / 1073741824.0, 6)          AS data_out_gb,
        SUM(v.total_packets)                                 AS total_packets,
        v.year, v.month, v.day,
        {LOG_DATE_SQL}                                       AS log_date
    FROM vpc_egress_base v
    LEFT JOIN deduped_dns d
        ON  v.dstaddr    = d.resolved_ip
        AND v.srcaddr    = d.srcaddr
        AND v.account_id = d.account_id
        AND v.vpc_id     = d.vpc_id
        AND v.year       = d.year
        AND v.month      = d.month
        AND v.day        = d.day
    LEFT JOIN ec2_full e
        ON  v.account_id  = e.account_id
        AND v.region      = e.region
        AND v.instance_id = e.instance_id
    LEFT JOIN acct_biz_lookup a
        ON  v.account_id = a.account_id
        AND v.region     = a.region
    LEFT JOIN ip_metadata m ON v.dstaddr = m.dstaddr
    GROUP BY
        COALESCE(e.account_name,  a.account_name, 'UNKNOWN'),
        COALESCE(e.biz_unit,      a.biz_unit,     'UNKNOWN'),
        COALESCE(e.application_id,                'UNKNOWN'),
        v.account_id, v.region, v.vpc_id, v.instance_id,
        v.srcaddr, v.dstaddr, d.primary_domain,
        v.pkt_dst_aws_service, v.traffic_path,
        m.country_name, m.asn_org,
        m.final_service_type, m.aws_region,
        v.year, v.month, v.day
    ORDER BY total_bytes DESC
""")

write_to_postgres(agg10_df, "network_intelligence_final", [
