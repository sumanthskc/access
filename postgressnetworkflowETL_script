import sys
import io
import psycopg2
from awsglue.utils import getResolvedOptions
from pyspark.context import SparkContext
from awsglue.context import GlueContext
from awsglue.job import Job
from pyspark.sql import functions as F

# ──────────────────────────────────────────────────────────────
# INIT
# ──────────────────────────────────────────────────────────────
args = getResolvedOptions(sys.argv, ['JOB_NAME', 'year', 'month', 'day'])

sc          = SparkContext()
glueContext = GlueContext(sc)
spark       = glueContext.spark_session
job         = Job(glueContext)
job.init(args['JOB_NAME'], args)

spark.conf.set("spark.sql.shuffle.partitions",         "20")
spark.conf.set("spark.sql.parquet.mergeSchema",        "false")
spark.conf.set("spark.sql.parquet.filterPushdown",     "true")
spark.conf.set("spark.sql.autoBroadcastJoinThreshold", "209715200")  # 200MB
spark.conf.set("spark.sql.broadcastTimeout",           "600")

# ── Parameters ────────────────────────────────────────────────
year    = args['year']
month   = args['month']
day     = args['day']
month_p = month.zfill(2)
day_p   = day.zfill(2)
log_date_str = f"{year}-{month_p}-{day_p}"

print(f"{'=' * 60}")
print(f"ETL Start: {log_date_str}")
print(f"{'=' * 60}")

# ──────────────────────────────────────────────────────────────
# POSTGRESQL CONFIG
# ──────────────────────────────────────────────────────────────
PG_HOST = "10.88.32.172"
PG_PORT = "5432"
PG_DB   = "networklogs"
PG_USER = "glue_user"
PG_PASS = "user"

# ──────────────────────────────────────────────────────────────
# S3 PATHS
# ──────────────────────────────────────────────────────────────
VPC_BASE  = "s3://ist-network-intelligence-vpcflowlogs-curated/vpcflowlogs/"
VPC_PATH  = f"{VPC_BASE}*/*/year={year}/month={month}/day={day}/"
R53_BASE  = "s3://ist-network-intelligence-vpcflowlogs-curated/vpcdnsquerylogs-curated/"
R53_PATH  = f"{R53_BASE}*/*/year={year}/month={month}/day={day}/"
META_BASE = "s3://ist-network-intelligence-vpcflowlogs-curated/meta_data_tables/"

# ──────────────────────────────────────────────────────────────
# WRITE HELPER — chunked copy_expert
# ──────────────────────────────────────────────────────────────
def write_to_postgres(df, table_name, columns, chunk_size=50000):
    col_str = ", ".join(columns)
    _host   = PG_HOST
    _port   = PG_PORT
    _db     = PG_DB
    _user   = PG_USER
    _pass   = PG_PASS
    _chunk  = chunk_size

    def write_partition(partition):
        conn   = psycopg2.connect(host=_host, port=_port, dbname=_db, user=_user, password=_pass)
        cur    = conn.cursor()
        buffer = io.StringIO()
        count  = 0
        for row in partition:
            buffer.write("\t".join(["" if v is None else str(v) for v in row]) + "\n")
            count += 1
            if count >= _chunk:
                buffer.seek(0)
                cur.copy_expert(f"COPY public.{table_name} ({col_str}) FROM STDIN WITH (FORMAT TEXT, NULL '')", buffer)
                conn.commit()
                buffer = io.StringIO()
                count  = 0
        if count > 0:
            buffer.seek(0)
            cur.copy_expert(f"COPY public.{table_name} ({col_str}) FROM STDIN WITH (FORMAT TEXT, NULL '')", buffer)
            conn.commit()
        cur.close()
        conn.close()

    df.select(columns).coalesce(10).rdd.foreachPartition(write_partition)
    print(f"  ✅ Written to: {table_name}")

# ──────────────────────────────────────────────────────────────
# REUSABLE SQL SNIPPETS
# ──────────────────────────────────────────────────────────────
LOG_DATE_SQL = f"TO_DATE(CONCAT(year, '-', LPAD(month, 2, '0'), '-', LPAD(day, 2, '0')), 'yyyy-MM-dd')"

# ──────────────────────────────────────────────────────────────
# STEP 1: READ ALL SOURCES
# ──────────────────────────────────────────────────────────────
print("\n[SETUP 1/5] Reading S3 sources...")

# Full VPC logs (needed for AGG 4 — all traffic)
vpc_df = spark.read \
    .option("mergeSchema", "false") \
    .option("basePath",    VPC_BASE) \
    .parquet(VPC_PATH) \
    .dropna(subset=["srcaddr", "dstaddr", "account_id"]) \
    .withColumn("log_date", F.to_date(F.lit(log_date_str), "yyyy-MM-dd")) \
    .withColumn("dst_ip_int",
        F.conv(F.concat(
            F.lpad(F.hex(F.split(F.col("dstaddr"), r"\.")[0].cast("int")), 2, "0"),
            F.lpad(F.hex(F.split(F.col("dstaddr"), r"\.")[1].cast("int")), 2, "0"),
            F.lpad(F.hex(F.split(F.col("dstaddr"), r"\.")[2].cast("int")), 2, "0"),
            F.lpad(F.hex(F.split(F.col("dstaddr"), r"\.")[3].cast("int")), 2, "0")
        ), 16, 10).cast("long")
    )

# Pre-filtered egress view — reused by AGG 1,2,3,5,6,7,8,9,10
vpc_egress_df = vpc_df.filter(
    (F.col("flow_direction") == "egress") &
    (~F.col("dstaddr").startswith("10.")) &
    (~F.col("dstaddr").startswith("172.16.")) &
    (~F.col("dstaddr").startswith("192.168."))
)

# Route53 logs
r53_df = spark.read \
    .option("mergeSchema", "false") \
    .option("basePath",    R53_BASE) \
    .parquet(R53_PATH) \
    .select("account_id", "region", "vpc_id", "srcaddr",
            "srcport", "srcids", "query_name", "query_type",
            "answers", "rcode", "transport", "version",
            "year", "month", "day")

# Metadata tables
ec2_df     = spark.read.option("mergeSchema", "false").parquet(f"{META_BASE}ec2_details_parquet/")
geo_blk_df = spark.read.option("mergeSchema", "false").parquet(f"{META_BASE}geo_country_blocks_range_parquet/")
geo_loc_df = spark.read.option("mergeSchema", "false").parquet(f"{META_BASE}geo_country_locations_parquet/")
geo_asn_df = spark.read.option("mergeSchema", "false").parquet(f"{META_BASE}geo_asn_blocks_range_parquet/")
aws_ip_df  = spark.read.option("mergeSchema", "false").parquet(f"{META_BASE}aws_ip_ranges_int_parquet/")

print("  ✅ All sources loaded")

# ──────────────────────────────────────────────────────────────
# STEP 2: CACHE
# ──────────────────────────────────────────────────────────────
print("\n[SETUP 2/5] Caching datasets...")

vpc_df.cache()
vpc_egress_df.cache()
r53_df.cache()
ec2_df.cache()
geo_blk_df.cache()
geo_loc_df.cache()
geo_asn_df.cache()
aws_ip_df.cache()

print("  ✅ All cached")

# ──────────────────────────────────────────────────────────────
# STEP 3: BUILD REUSABLE INTERMEDIATE RESULTS
# ──────────────────────────────────────────────────────────────
print("\n[SETUP 3/5] Building reusable intermediate results...")

# ── 3a: Account lookup (reused in ALL aggregations) ───────────
acct_df = ec2_df.select("account_id", "account_name") \
    .distinct()
acct_df.cache()
acct_df.createOrReplaceTempView("acct_lookup")

# ── 3b: Full EC2 instance lookup (reused in AGG 6, 10) ────────
ec2_full_df = ec2_df.select(
    "account_id", "region", "instance_id",
    "account_name", "biz_unit", "application_id"
).distinct()
ec2_full_df.cache()
ec2_full_df.createOrReplaceTempView("ec2_full")

# ── 3c: Account + biz_unit fallback (reused in AGG 6, 10) ─────
acct_biz_df = ec2_df.select(
    "account_id", "region", "account_name", "biz_unit"
).distinct()
acct_biz_df.cache()
acct_biz_df.createOrReplaceTempView("acct_biz_lookup")

# ── 3d: IP Metadata — geo join on DISTINCT IPs only ───────────
# This is the key optimization:
# Instead of joining geo tables against 50M rows
# we join against ~10K unique destination IPs
print("  Building IP metadata on distinct IPs...")

distinct_ips_df = vpc_egress_df \
    .select("dstaddr", "dst_ip_int") \
    .distinct()

ip_metadata_df = distinct_ips_df \
    .join(
        F.broadcast(geo_blk_df),
        (F.col("dst_ip_int") >= geo_blk_df.network_start_integer) &
        (F.col("dst_ip_int") <= geo_blk_df.network_end_integer),
        "left"
    ) \
    .join(
        F.broadcast(geo_loc_df),
        "geoname_id",
        "left"
    ) \
    .join(
        F.broadcast(geo_asn_df),
        (F.col("dst_ip_int") >= geo_asn_df.network_start_integer) &
        (F.col("dst_ip_int") <= geo_asn_df.network_end_integer),
        "left"
    ) \
    .join(
        F.broadcast(aws_ip_df),
        (F.col("dst_ip_int") >= aws_ip_df.network_start_int) &
        (F.col("dst_ip_int") <= aws_ip_df.network_end_int),
        "left"
    ) \
    .select(
        F.col("dstaddr"),
        F.col("country_name"),
        F.col("autonomous_system_organization").alias("asn_org"),
        F.coalesce(F.col("service"), F.lit("NON-AWS")).alias("final_service_type"),
        F.col("aws_ip_ranges.region").alias("aws_region")
    ) \
    .dropDuplicates(["dstaddr"])

ip_metadata_df.cache()
ip_metadata_df.createOrReplaceTempView("ip_metadata")

print("  ✅ IP metadata built")

# ── 3e: Deduped DNS — computed ONCE, reused in AGG 9 + 10 ─────
print("  Building deduped DNS lookup...")

deduped_dns_df = r53_df \
    .filter(F.col("rcode") == "NOERROR") \
    .select(
        "account_id", "vpc_id", "srcaddr",
        "query_name", "answers",
        "year", "month", "day"
    ) \
    .withColumn("ans", F.explode("answers")) \
    .withColumn("resolved_ip", F.col("ans.Rdata")) \
    .withColumn("domain",      F.col("query_name")) \
    .groupBy("account_id", "vpc_id", "srcaddr",
             "resolved_ip", "year", "month", "day") \
    .agg(
        F.expr("MAX_BY(domain, count(*))").alias("primary_domain")
    )

deduped_dns_df.cache()
deduped_dns_df.createOrReplaceTempView("deduped_dns")

print("  ✅ DNS lookup built")

# ── 3f: VPC Egress Aggregated Base (reused in AGG 9, 10) ──────
# Pre-aggregate vpc_egress to reduce rows before DNS + geo joins
print("  Building VPC egress base aggregation...")

vpc_egress_base_df = vpc_egress_df \
    .filter(F.col("log_status") == "OK") \
    .groupBy(
        "account_id", "region", "vpc_id", "instance_id",
        "srcaddr", "dstaddr", "dstport",
        "pkt_dst_aws_service", "traffic_path",
        "year", "month", "day"
    ) \
    .agg(
        F.sum("bytes").alias("total_bytes"),
        F.sum("packets").alias("total_packets"),
        F.count("*").alias("flow_count")
    )

vpc_egress_base_df.cache()
vpc_egress_base_df.createOrReplaceTempView("vpc_egress_base")

print("  ✅ VPC egress base built")

# ──────────────────────────────────────────────────────────────
# STEP 4: REGISTER ALL TEMP VIEWS
# ──────────────────────────────────────────────────────────────
print("\n[SETUP 4/5] Registering temp views...")

vpc_df.createOrReplaceTempView("vpc_logs")
vpc_egress_df.createOrReplaceTempView("vpc_egress")
r53_df.createOrReplaceTempView("r53_logs")
ec2_df.createOrReplaceTempView("ec2_details")

print("  ✅ All views registered")
print(f"\n{'=' * 60}")
print(f"Starting Aggregations for {log_date_str}")
print(f"{'=' * 60}\n")

# ──────────────────────────────────────────────────────────────
# AGG 1: Total Internet Egress
# Uses: vpc_egress, acct_lookup
# ──────────────────────────────────────────────────────────────
print("[AGG 1] Total Internet Egress...")

agg1_df = spark.sql(f"""
    SELECT
        COALESCE(e.account_name, 'UNKNOWN')   AS account_name,
        v.account_id, v.region, v.vpc_id,
        ROUND(SUM(v.bytes) / 1073741824.0, 6) AS total_gb,
        v.year, v.month, v.day,
        {LOG_DATE_SQL}                        AS log_date
    FROM vpc_egress v
    LEFT JOIN acct_lookup e ON v.account_id = e.account_id
    GROUP BY
        e.account_name, v.account_id, v.region,
        v.vpc_id, v.year, v.month, v.day
""")

write_to_postgres(agg1_df, "total_internet_egress", [
    "account_name", "account_id", "region", "vpc_id",
    "total_gb", "year", "month", "day", "log_date"
])

