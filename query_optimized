CREATE TABLE unified_network_analysis
WITH (
     format = 'PARQUET',
     external_location = 's3://ist-network-intelligence-vpcflowlogs-curated/preaggregate/unified_layer/',
     partitioned_by = ARRAY['year', 'month', 'day']
) AS

WITH dns_logs AS (
    SELECT 
        account_id, 
        vpc_id, 
        srcaddr AS client_ip, 
        query_name AS domain, 
        ans.rdata AS resolved_ip,
        rcode,
        from_iso8601_timestamp(query_timestamp) AS dns_time,
        -- Create an exact equality bucket to force a high-performance Hash Join
        date_trunc('hour', from_iso8601_timestamp(query_timestamp)) AS hour_bucket
    FROM route53_vpc_dns_query_logs_curated
    -- Use LEFT JOIN UNNEST to preserve NXDOMAIN and SERVFAIL queries
    LEFT JOIN UNNEST(answers) as t_ans(ans) 
),

flow_logs AS (
    SELECT 
        account_id, 
        region, 
        vpc_id, 
        instance_id, 
        interface_id,  -- Required to uniquely identify the specific network interface
        pkt_srcaddr, 
        pkt_dstaddr, 
        pkt_dst_aws_service, 
        traffic_path,
        bytes, 
        packets,
        from_unixtime(start_time) AS flow_start_time,
        -- Create an exact equality bucket for the Flow Log
        date_trunc('hour', from_unixtime(start_time)) AS hour_bucket,
        year, month, day
    FROM vpc_flow_logs_curated
    WHERE flow_direction = 'egress' 
      AND log_status = 'OK'
      AND (tcp_flags = 2 OR protocol = 17) -- Filter massive datasets before joining
),

joined_data AS (
    SELECT 
        v.account_id,
        v.region,
        v.vpc_id,
        v.instance_id,
        v.pkt_srcaddr,
        v.pkt_dstaddr,
        r.domain, 
        v.pkt_dst_aws_service, 
        v.traffic_path,
        v.bytes,
        v.packets,
        v.year, v.month, v.day,
        -- DEDUPLICATION LOGIC: Rank the matched domains by how close they are to the flow start time
        ROW_NUMBER() OVER (
            PARTITION BY v.interface_id, v.pkt_srcaddr, v.pkt_dstaddr, v.flow_start_time 
            ORDER BY r.dns_time DESC
        ) as row_num
    FROM flow_logs v
    LEFT JOIN dns_logs r 
        -- 1. Exact equality matches ensure Athena uses a fast Distributed Hash Join
        ON v.hour_bucket = r.hour_bucket
        AND v.pkt_srcaddr = r.client_ip
        AND v.pkt_dstaddr = r.resolved_ip
        AND v.vpc_id = r.vpc_id
        AND v.account_id = r.account_id
        -- 2. The secondary temporal filter guarantees strict timeline accuracy
        AND v.flow_start_time BETWEEN r.dns_time AND (r.dns_time + INTERVAL '10' MINUTE)
)

-- Final Selection: Filter out the duplicates generated by the join
SELECT 
    account_id,
    region,
    vpc_id,
    instance_id,
    pkt_srcaddr AS client_ip,
    pkt_dstaddr AS destination_ip,
    domain, 
    pkt_dst_aws_service, 
    traffic_path,
    -- Safely sum metrics now that duplicates are eliminated
    SUM(bytes) AS total_bytes,
    SUM(packets) AS total_packets,
    year, month, day
FROM joined_data
WHERE row_num = 1 -- Only keep the most recent domain resolution for this specific network flow
GROUP BY 
    account_id, region, vpc_id, instance_id, pkt_srcaddr, 
    pkt_dstaddr, domain, pkt_dst_aws_service, traffic_path,
    year, month, day;
