INSERT INTO "s3tablescatalog/vpc-flow-logs-table-bucket".vpc_flow_logs.joined_logs
WITH daily_raw AS (
    -- Step 1: Filter to a single day
    SELECT *
    FROM "s3tablescatalog/vpc-flow-logs-table-bucket".vpc_flow_logs.raw_flow_logs
    WHERE instance_id IS NOT NULL
      AND year = '2026'
      AND month = '02'
      AND day = '16'
),
ranked_flows AS (
    -- Step 2: Rank flows by total_bytes within each Account, Region, and VPC
    SELECT 
        *,
        ROW_NUMBER() OVER(
            PARTITION BY account_id, region, vpc_id 
            ORDER BY total_bytes DESC
        ) as rnk
    FROM daily_raw
),
top_flows AS (
    -- Step 3: Keep only the Top 300 per group, and calculate the IP integer
    SELECT 
        *,
        (
          CAST(split_part(destination_ip, '.', 1) AS bigint) * 16777216 +
          CAST(split_part(destination_ip, '.', 2) AS bigint) * 65536 +
          CAST(split_part(destination_ip, '.', 3) AS bigint) * 256 +
          CAST(split_part(destination_ip, '.', 4) AS bigint)
        ) AS ip_int
    FROM ranked_flows
    WHERE rnk <= 300
)
SELECT
    u.account_name,
    u.biz_units,
    u.application_id,
    u.instance_id,
    u.client_ip AS srcaddr,
    u.destination_ip AS dstaddr,
    u.domain AS query_name,
    loc.country_name,
    a.autonomous_system_organization AS asn_org,
    
    -- Final Service Classification
    COALESCE(aws.service, 'NON-AWS') AS final_service_type,
    aws.region AS aws_region,
    
    -- Region Scope
    CASE
        WHEN aws.service IS NULL THEN 'Internet'
        WHEN aws.region = u.region THEN 'Same-Region'
        ELSE 'Cross-Region'
    END AS region_scope,
    
    u.total_bytes,
    
    -- Partition columns explicitly placed at the end in correct order
    u.account_id,
    u.region,
    u.vpc_id,
    u.year,
    u.month,
    u.day

FROM top_flows u

-- Step 4: Execute the heavy IP lookups ONLY on the filtered top rows
LEFT JOIN geo_country_blocks_range g 
    ON u.ip_int BETWEEN g.network_start_integer AND g.network_end_integer
LEFT JOIN geo_country_locations loc 
    ON g.geoname_id = loc.geoname_id
LEFT JOIN geo_asn_blocks_range a 
    ON u.ip_int BETWEEN a.network_start_integer AND a.network_end_integer
LEFT JOIN networkautomation.aws_ip_ranges_int aws 
    ON u.ip_int BETWEEN aws.network_start_int AND aws.network_end_int
    AND aws.service = u.pkt_dst_aws_service;
